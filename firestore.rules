rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: accounts/{uid}/profile
    // Document ID: main
    // Fields:
    //   - encryptionSalt: string (required) - Base64 encoded salt for key derivation.
    //   - verificationVector: string (required) - JSON string used to verify passphrase.
    //   - setupComplete: boolean (required) - Whether the user has completed initial setup.
    //   - createdAt: number (required) - Timestamp of account creation.
    //   - avatar: object (optional) - Encrypted avatar data (ciphertext and iv).
    //
    // Collection: accounts/{uid}/devices
    // Document ID: {deviceId}
    // Fields:
    //   - name: string (required) - User-defined name for the device.
    //   - platform: string (required) - Platform of the device (e.g., android, ios, web).
    //   - addedAt: number (required) - Timestamp of when the device was added.
    //   - lastSeen: number (required) - Timestamp of when the device was last seen.
    //
    // Collection: accounts/{uid}/messages
    // Document ID: {msgId}
    // Fields:
    //   - ciphertext: string (required) - Encrypted message content.
    //   - iv: string (required) - Initialization vector for decryption.
    //   - type: string (required) - Type of message (e.g., text, image, file).
    //   - deviceId: string (required) - ID of the sending device.
    //   - deviceName: string (required) - Name of the sending device.
    //   - timestamp: number (required) - Server timestamp of the message.
    //   - edited: boolean (optional) - Whether the message has been edited.
    //   - editedAt: number (optional) - Timestamp of the last edit.
    //   - deleted: boolean (optional) - Whether the message has been soft-deleted.
    //   - pinned: boolean (optional) - Whether the message is pinned.
    //   - replyTo: string (optional) - ID of the message being replied to.
    //   - readBy: map (optional) - Map of device IDs to read timestamps.
    //   - uuid: string (optional) - UUID of the media file in Drive.
    //   - fileName: string (optional) - Original name of the media file.
    //   - fileSize: number (optional) - Size of the media file in bytes.
    //   - mimeType: string (optional) - MIME type of the media file.
    //   - encThumb: map (optional) - Encrypted thumbnail data.
    //
    // Collection: accounts/{uid}/typing
    // Document ID: {deviceId}
    // Fields:
    //   - isTyping: boolean (required) - Whether the device is typing.
    //   - updatedAt: number (required) - Timestamp of the last update.
    //
    // Collection: accounts/{uid}/presence
    // Document ID: {deviceId}
    // Fields:
    //   - online: boolean (required) - Whether the device is online.
    //   - lastSeen: number (required) - Timestamp of when the device was last seen.
    //   - deviceName: string (required) - Name of the device.
    //
    // Collection: accounts/{uid}/spineConfig
    // Document ID: main
    // Fields:
    //   - accounts: list (required) - List of Drive accounts linked to the Nexus account.
    //
    // Collection: accounts/{uid}/mediaManifest
    // Document ID: {uuid}
    // Fields:
    //   - driveUid: string (required)
    //   - driveFileId: string (required)
    //   - folderId: string (required)
    //   - size: number (required)
    //   - originalSize: number (optional)
    //   - mimeType: string (required)
    //   - fileName: string (optional)
    //   - addedAt: number (required)
    //   - status: string (required) - "live" or "missing"
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidProfile(data) {
      return hasRequiredFields(['encryptionSalt', 'verificationVector', 'setupComplete', 'createdAt']) &&
             data.encryptionSalt is string && data.encryptionSalt.size() > 0 && data.encryptionSalt.size() < 1000 &&
             data.verificationVector is string && data.verificationVector.size() > 0 && data.verificationVector.size() < 5000 &&
             data.setupComplete is bool &&
             data.createdAt is number;
    }

    function isValidDevice(data) {
      return hasRequiredFields(['name', 'platform', 'addedAt', 'lastSeen']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.platform is string && data.platform.size() > 0 && data.platform.size() < 50 &&
             data.addedAt is number &&
             data.lastSeen is number;
    }

    function isValidMessage(data) {
      return hasRequiredFields(['ciphertext', 'iv', 'type', 'deviceId', 'deviceName', 'timestamp']) &&
             data.ciphertext is string && data.ciphertext.size() > 0 && data.ciphertext.size() < 1000000 &&
             data.iv is string && data.iv.size() > 0 && data.iv.size() < 100 &&
             data.type is string &&
             data.deviceId is string &&
             data.deviceName is string &&
             data.timestamp is number;
    }

    function isValidTyping(data) {
      return hasRequiredFields(['isTyping', 'updatedAt']) &&
             data.isTyping is bool &&
             data.updatedAt is number;
    }

    function isValidPresence(data) {
      return hasRequiredFields(['online', 'lastSeen', 'deviceName']) &&
             data.online is bool &&
             data.lastSeen is number &&
             data.deviceName is string;
    }

    function isValidSpineConfig(data) {
      return hasRequiredFields(['accounts']) &&
             data.accounts is list;
    }

    function isValidMediaManifest(data) {
      return hasRequiredFields(['driveUid', 'driveFileId', 'folderId', 'size', 'mimeType', 'addedAt', 'status']) &&
             data.driveUid is string &&
             data.driveFileId is string &&
             data.folderId is string &&
             data.size is number &&
             data.mimeType is string &&
             data.addedAt is number &&
             data.status in ['live', 'missing'];
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /accounts/{uid} {
      
      match /profile/main {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidProfile(request.resource.data);
        allow update: if isOwner(uid) && isValidProfile(request.resource.data);
      }

      match /devices/{deviceId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidDevice(request.resource.data);
        allow update: if isOwner(uid) && isValidDevice(request.resource.data);
      }

      match /messages/{msgId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidMessage(request.resource.data);
        allow update: if isOwner(uid) && isValidMessage(request.resource.data);
        allow delete: if isOwner(uid);
      }

      match /typing/{deviceId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidTyping(request.resource.data);
        allow update: if isOwner(uid) && isValidTyping(request.resource.data);
      }

      match /presence/{deviceId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidPresence(request.resource.data);
        allow update: if isOwner(uid) && isValidPresence(request.resource.data);
      }

      match /spineConfig/main {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidSpineConfig(request.resource.data);
        allow update: if isOwner(uid) && isValidSpineConfig(request.resource.data);
      }

      match /mediaManifest/{uuid} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidMediaManifest(request.resource.data);
        allow update: if isOwner(uid) && isValidMediaManifest(request.resource.data);
        allow delete: if isOwner(uid);
      }
    }
  }
}
